{
  "name": "fichaje-desktop",
  "version": "3.1.0",
  "description": "Sistema de Fichaje — Aplicación de escritorio V3.1 autocontenida",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "seed": "node ./backend/seed.js",
    "backend:dev": "node ./backend/server.js",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "build:panel": "cd ../admin_panel && npm run build",
    "build:win": "npm run build:panel && npm run rebuild && electron-builder --win",
    "build:mac": "npm run build:panel && npm run rebuild && electron-builder --mac",
    "build:linux": "npm run build:panel && npm run rebuild && electron-builder --linux"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.7.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "electron": "39.8.9",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.fichaje.desktop",
    "productName": "Fichaje",
    "copyright": "Copyright © 2026",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*.node"
    ],
    "files": [
      "src/**/*",
      "backend/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*",
      ".env.example"
    ],
    "extraResources": [
      {
        "from": "../admin_panel/dist",
        "to": "panel_dist"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Fichaje"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}
<Window x:Class="FichajeDeEmpresa.App.FichajeHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Historial detallado de fichajes"
        Height="680"
        Width="1140"
        MinHeight="620"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppCardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Historial detallado de fichajes"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Usuario"
                                   Style="{StaticResource AppFieldLabelStyle}" />
                        <ComboBox x:Name="HistoryUserComboBox"
                                  Style="{StaticResource AppComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fecha desde"
                                   Style="{StaticResource AppFieldLabelStyle}" />
                        <DatePicker x:Name="FromDatePicker"
                                    Style="{StaticResource AppDatePickerStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Fecha hasta"
                                   Style="{StaticResource AppFieldLabelStyle}" />
                        <DatePicker x:Name="ToDatePicker"
                                    Style="{StaticResource AppDatePickerStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="6"
                                VerticalAlignment="Bottom">
                        <Button x:Name="SearchButton"
                                Width="130"
                                Content="Buscar"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="SearchButton_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource AppCardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="HistorySummaryTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Sin resultados cargados todavía." />

                    <Border x:Name="MessageBorder"
                            Margin="0,12,0,0"
                            Background="{StaticResource DangerBackgroundBrush}"
                            BorderBrush="{StaticResource DangerBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Visibility="Collapsed">
                        <TextBlock x:Name="MessageTextBlock"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2">
                    <ListBox x:Name="HistoryListBox"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        Background="{StaticResource SoftCardBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DateText}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding UserText}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />

                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Trabajado"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding WorkedText}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Extra"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding ExtraText}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Estado"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding StatusText}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="5"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Movimientos"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Text="{Binding MovementsText}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="6"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right">
                                            <Button Width="110"
                                                    Height="36"
                                                    Content="Ver detalle"
                                                    Tag="{Binding DayData}"
                                                    Style="{StaticResource AppPrimaryButtonStyle}"
                                                    Click="ViewDetailButton_Click" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border x:Name="EmptyStateBorder"
                            Style="{StaticResource AppSoftCardBorderStyle}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Visibility="Collapsed">
                        <TextBlock Text="No hay resultados."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
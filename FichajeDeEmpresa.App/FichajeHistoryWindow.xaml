<Window x:Class="FichajeDeEmpresa.App.FichajeHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Historial detallado de fichajes"
        Height="700"
        Width="1180"
        MinHeight="660"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#EEF2F7">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D9E1EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,0" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Historial detallado de fichajes"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#17212B" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Usuario"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox x:Name="HistoryUserComboBox"
                                  Height="40"
                                  FontSize="14"
                                  Padding="8,4" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fecha desde"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <DatePicker x:Name="FromDatePicker"
                                    Height="40"
                                    FontSize="14" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Fecha hasta"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <DatePicker x:Name="ToDatePicker"
                                    Height="40"
                                    FontSize="14" />
                    </StackPanel>

                    <StackPanel Grid.Column="6"
                                VerticalAlignment="Bottom">
                        <Button x:Name="SearchButton"
                                Width="130"
                                Content="Buscar"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SearchButton_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="HistorySummaryTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#475569"
                               Text="Sin resultados cargados todavía." />

                    <Border x:Name="MessageBorder"
                            Margin="0,12,0,0"
                            Padding="12"
                            CornerRadius="12"
                            Background="#FDECEC"
                            BorderBrush="#F2B8B5"
                            BorderThickness="1"
                            Visibility="Collapsed">
                        <TextBlock x:Name="MessageTextBlock"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#9F1239"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>

                <ListBox Grid.Row="2"
                         x:Name="HistoryListBox"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    Padding="16"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="17"
                                               FontWeight="Bold"
                                               Foreground="#17212B" />

                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding Summary}"
                                               FontSize="13"
                                               Foreground="#475569"
                                               TextWrapping="Wrap" />

                                    <ItemsControl Margin="0,12,0,0"
                                                  ItemsSource="{Binding Movements}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="12"
                                                        Background="White"
                                                        BorderBrush="#E2E8F0"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding TimeText}"
                                                                       FontSize="13"
                                                                       FontWeight="Bold"
                                                                       Foreground="#17212B" />
                                                            <TextBlock Margin="10,0,0,0"
                                                                       Text="{Binding TypeText}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#2563EB" />
                                                        </StackPanel>

                                                        <TextBlock Margin="0,8,0,0"
                                                                   Text="{Binding CommentText, StringFormat=Comentario: {0}}"
                                                                   FontSize="13"
                                                                   Foreground="#475569"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2"
                        x:Name="EmptyStateBorder"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="22"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Visibility="Collapsed">
                    <TextBlock Text="No hay resultados."
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#475569" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
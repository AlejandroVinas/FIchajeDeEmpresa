<Window x:Class="FichajeDeEmpresa.App.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HIFLUNECAN S.L. - Administración"
        Height="760"
        Width="1240"
        MinHeight="680"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        WindowState="Maximized"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppCardBorderStyle}"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="96"
                        Height="72"
                        CornerRadius="14"
                        Background="{StaticResource InfoBackgroundBrush}"
                        BorderBrush="{StaticResource InfoBorderBrush}"
                        BorderThickness="1"
                        Padding="10"
                        VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/Images/hiflunecan.png"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderCompanyNameTextBlock"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock x:Name="HeaderBrandTextBlock"
                               Margin="0,4,0,0"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandPrimaryDarkBrush}" />

                    <TextBlock x:Name="WelcomeTextBlock"
                               Margin="0,12,0,0"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>

                <Border Grid.Column="4"
                        MinWidth="260"
                        Style="{StaticResource AppSoftCardBorderStyle}"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Sesión actual"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,8" />

                        <TextBlock x:Name="SessionUserNameTextBlock"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <TextBlock x:Name="SessionRoleTextBlock"
                                   Margin="0,5,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" />

                        <Button x:Name="ChangeUserButton"
                                Margin="0,16,0,0"
                                Width="160"
                                Content="Cambiar usuario"
                                HorizontalAlignment="Left"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Click="ChangeUserButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <WrapPanel ItemWidth="470"
                       ItemHeight="300">
                <Border Width="470"
                        Height="300"
                        Margin="0,0,18,18"
                        Style="{StaticResource AppCardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Gestión de usuarios"
                                   Style="{StaticResource AppSectionTitleStyle}" />

                        <Border Grid.Row="2"
                                Style="{StaticResource AppSoftCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Usuarios"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />

                                <TextBlock Margin="0,14,0,0"
                                           Text="Ver usuarios del sistema"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}" />

                                <TextBlock Margin="0,8,0,0"
                                           Text="Crear nuevos usuarios"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Button Grid.Row="4"
                                x:Name="OpenUsersButton"
                                Width="210"
                                Content="Abrir gestión de usuarios"
                                HorizontalAlignment="Left"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="OpenUsersButton_Click" />
                    </Grid>
                </Border>

                <Border Width="470"
                        Height="300"
                        Margin="0,0,0,18"
                        Style="{StaticResource AppCardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Historial de fichajes"
                                   Style="{StaticResource AppSectionTitleStyle}" />

                        <Border Grid.Row="2"
                                Style="{StaticResource AppSoftCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Historial"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />

                                <TextBlock Margin="0,14,0,0"
                                           Text="Filtrar por usuario"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}" />

                                <TextBlock Margin="0,8,0,0"
                                           Text="Filtrar por fechas"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}" />

                                <TextBlock Margin="0,8,0,0"
                                           Text="Consultar detalle del día"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Button Grid.Row="4"
                                x:Name="OpenHistoryButton"
                                Width="210"
                                Content="Abrir historial"
                                HorizontalAlignment="Left"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="OpenHistoryButton_Click" />
                    </Grid>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Window>
<Window x:Class="FichajeDeEmpresa.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HIFLUNECAN S.L. - Control de fichaje"
        Height="720"
        Width="1240"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        WindowState="Maximized"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Border Grid.Row="0"
                Style="{StaticResource AppCardBorderStyle}"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="290" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="96"
                        Height="76"
                        CornerRadius="16"
                        Background="{StaticResource InfoBackgroundBrush}"
                        BorderBrush="{StaticResource InfoBorderBrush}"
                        BorderThickness="1"
                        Padding="10"
                        VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/Images/hiflunecan.png"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderCompanyNameTextBlock"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock x:Name="HeaderBrandTextBlock"
                               Margin="0,4,0,0"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandPrimaryDarkBrush}" />

                    <TextBlock x:Name="WelcomeTextBlock"
                               Margin="0,12,0,4"
                               FontSize="19"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="Bienvenido/a" />

                    <TextBlock x:Name="HeaderWelcomeMessageTextBlock"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="4"
                        Style="{StaticResource AppSoftCardBorderStyle}"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Sesión actual"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,8" />

                        <TextBlock x:Name="SessionUserNameTextBlock"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />

                        <TextBlock x:Name="SessionRoleTextBlock"
                                   Margin="0,5,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" />

                        <TextBlock x:Name="SessionDailyHoursTextBlock"
                                   Margin="0,3,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" />

                        <Button x:Name="ChangeUserButton"
                                Width="155"
                                Margin="0,16,0,0"
                                HorizontalAlignment="Left"
                                Content="Cambiar usuario"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Click="ChangeUserButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- CUERPO -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- COLUMNA IZQUIERDA -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- RESUMEN -->
                <Border Grid.Row="0"
                        Style="{StaticResource AppCardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tu jornada de hoy"
                                           Style="{StaticResource AppSectionTitleStyle}" />
                                <TextBlock x:Name="CurrentSituationTextBlock"
                                           Margin="0,6,0,0"
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="Todavía no has empezado tu jornada." />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top">
                                <TextBlock Text="Estado"
                                           Style="{StaticResource AppFieldLabelStyle}" />
                                <Border x:Name="StatusBadgeBorder"
                                        Margin="0,8,0,0"
                                        Padding="12,6"
                                        CornerRadius="999"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource DangerBackgroundBrush}"
                                        BorderBrush="{StaticResource DangerBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock x:Name="StatusBadgeTextBlock"
                                               Text="FUERA"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource DangerBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource AppSoftCardBorderStyle}"
                                    MinHeight="128">
                                <StackPanel>
                                    <TextBlock Text="Tiempo trabajado"
                                               Style="{StaticResource AppMetricLabelStyle}" />
                                    <TextBlock x:Name="WorkedTodayValueTextBlock"
                                               Margin="0,16,0,0"
                                               Text="00:00:00"
                                               Style="{StaticResource AppMetricValueStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    x:Name="ExtraHoursCardBorder"
                                    Style="{StaticResource AppSoftCardBorderStyle}"
                                    MinHeight="128"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Horas extra"
                                               Style="{StaticResource AppMetricLabelStyle}" />
                                    <TextBlock x:Name="ExtraHoursValueTextBlock"
                                               Margin="0,16,0,0"
                                               Text="00:00:00"
                                               Style="{StaticResource AppMetricValueStyle}" />
                                    <TextBlock x:Name="ExtraHoursHintTextBlock"
                                               Margin="0,8,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Text="Hoy has generado horas extra." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ACCIONES -->
                <Border Grid.Row="2"
                        Style="{StaticResource AppCardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Acciones rápidas"
                                       Style="{StaticResource AppSectionTitleStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="Registra entrada, pausa, reanudación o salida."
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>

                        <WrapPanel Grid.Row="2">
                            <Button x:Name="EntryButton"
                                    Margin="0,0,10,10"
                                    Content="Fichar entrada"
                                    Style="{StaticResource AppSuccessButtonStyle}"
                                    Click="EntryButton_Click" />

                            <Button x:Name="PauseResumeButton"
                                    Margin="0,0,10,10"
                                    Content="Pausar"
                                    Style="{StaticResource AppWarningButtonStyle}"
                                    Click="PauseResumeButton_Click" />

                            <Button x:Name="ExitButton"
                                    Margin="0,0,10,10"
                                    Content="Fichar salida"
                                    Style="{StaticResource AppDangerButtonStyle}"
                                    Click="ExitButton_Click" />
                        </WrapPanel>

                        <Border Grid.Row="4"
                                Style="{StaticResource AppSoftCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Objetivo diario"
                                           Style="{StaticResource AppFieldLabelStyle}" />
                                <TextBlock x:Name="DailyTargetValueTextBlock"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource AppFieldValueStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- MENSAJES -->
                <Border Grid.Row="4"
                        x:Name="MessageBorder"
                        Style="{StaticResource AppCardBorderStyle}"
                        Padding="14"
                        Background="{StaticResource InfoBackgroundBrush}"
                        BorderBrush="{StaticResource InfoBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MessageTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InfoBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>

            <!-- COLUMNA DERECHA -->
            <Border Grid.Column="2"
                    Style="{StaticResource AppCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Movimientos de hoy"
                                   Style="{StaticResource AppSectionTitleStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Aquí ves tus registros de la jornada actual."
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <ListBox Grid.Row="2"
                             x:Name="MovementsListBox"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionMode="Single"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        Background="{StaticResource SoftCardBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock Text="{Binding}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
<Window x:Class="FichajeDeEmpresa.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Fichaje de Empresa - Pantalla principal"
        Height="700"
        Width="1050"
        MinHeight="700"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="24"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#D9DDE7"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="WelcomeTextBlock"
                               Text="Bienvenido/a"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,0,0,8" />

                    <TextBlock Text="Ya estás dentro de la aplicación. Desde aquí vamos a gestionar el estado actual y los fichajes del día."
                               FontSize="14"
                               Foreground="#666666"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="24"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#D9DDE7"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Usuario logueado"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20" />

                        <TextBlock Text="Id de usuario"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="UserIdValueTextBlock"
                                   Margin="0,4,0,16"
                                   FontSize="14" />

                        <TextBlock Text="Nombre completo"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="FullNameValueTextBlock"
                                   Margin="0,4,0,16"
                                   FontSize="14" />

                        <TextBlock Text="Rol"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="RoleValueTextBlock"
                                   Margin="0,4,0,16"
                                   FontSize="14" />

                        <TextBlock Text="Horas diarias configuradas"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="ExpectedDailyHoursValueTextBlock"
                                   Margin="0,4,0,0"
                                   FontSize="14" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="24"
                        Background="White"
                        CornerRadius="12"
                        BorderBrush="#D9DDE7"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Estado actual"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20" />

                        <TextBlock Text="Estado del usuario"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="CurrentStatusValueTextBlock"
                                   Margin="0,6,0,16"
                                   FontSize="20"
                                   FontWeight="Bold" />

                        <TextBlock Text="Última entrada"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="LastEntryValueTextBlock"
                                   Margin="0,6,0,16"
                                   FontSize="14" />

                        <TextBlock Text="Última salida"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="LastExitValueTextBlock"
                                   Margin="0,6,0,16"
                                   FontSize="14" />

                        <TextBlock Text="Tiempo trabajado hoy"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="WorkedTodayValueTextBlock"
                                   Margin="0,6,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4"
                    Padding="24"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#D9DDE7"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Fichajes del día"
                               FontSize="20"
                               FontWeight="Bold" />

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal">
                        <Button x:Name="EntryButton"
                                Content="Fichar entrada"
                                Width="150"
                                Height="42"
                                Margin="0,0,12,0"
                                FontWeight="SemiBold"
                                Click="EntryButton_Click" />

                        <Button x:Name="ExitButton"
                                Content="Fichar salida"
                                Width="150"
                                Height="42"
                                Margin="0,0,12,0"
                                FontWeight="SemiBold"
                                Click="ExitButton_Click" />

                        <Button x:Name="RefreshButton"
                                Content="Actualizar resumen"
                                Width="160"
                                Height="42"
                                FontWeight="SemiBold"
                                Click="RefreshButton_Click" />
                    </StackPanel>

                    <TextBlock Grid.Row="4"
                               x:Name="MessageTextBlock"
                               TextWrapping="Wrap"
                               FontSize="14" />

                    <Grid Grid.Row="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Movimientos de hoy"
                                   FontWeight="SemiBold"
                                   FontSize="16" />

                        <ListBox Grid.Row="2"
                                 x:Name="MovementsListBox"
                                 Height="220" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
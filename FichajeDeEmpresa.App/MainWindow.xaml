<Window x:Class="FichajeDeEmpresa.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Fichaje de Empresa - Login"
        Height="420"
        Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F6FA">
        <Border Width="360"
                Padding="24"
                Background="White"
                CornerRadius="12"
                BorderBrush="#D9DDE7"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>
                <TextBlock Text="Fichaje de Empresa"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,8" />

                <TextBlock Text="Primer paso: login conectado a la API"
                           FontSize="14"
                           Foreground="#666666"
                           Margin="0,0,0,20" />

                <TextBlock Text="Usuario" Margin="0,0,0,6" />
                <TextBox x:Name="UserNameTextBox"
                         Height="34"
                         FontSize="14"
                         Margin="0,0,0,14" />

                <TextBlock Text="Contraseña" Margin="0,0,0,6" />
                <PasswordBox x:Name="PasswordBox"
                             Height="34"
                             FontSize="14"
                             Margin="0,0,0,18"
                             KeyDown="PasswordBox_KeyDown" />

                <Button x:Name="LoginButton"
                        Content="Iniciar sesión"
                        Height="40"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Click="LoginButton_Click" />

                <TextBlock x:Name="StatusTextBlock"
                           Margin="0,16,0,0"
                           TextWrapping="Wrap"
                           Foreground="#B00020"
                           FontSize="13" />

                <Separator Margin="0,18,0,14" />

                <TextBlock Text="Usuarios de prueba"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <TextBlock Text="admin / admin123"
                           Foreground="#555555"
                           Margin="0,0,0,4" />

                <TextBlock Text="juan / 1234"
                           Foreground="#555555"
                           Margin="0,0,0,4" />

                <TextBlock Text="maria / 1234"
                           Foreground="#555555" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
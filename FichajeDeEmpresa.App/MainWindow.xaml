<Window x:Class="FichajeDeEmpresa.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HIFLUNECAN S.L. - Control de fichaje"
        Height="800"
        Width="1280"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D9E1EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#17212B" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748B" />
        </Style>

        <Style x:Key="FieldValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#17212B" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748B" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#17212B" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#15803D" />
            <Setter Property="BorderBrush" Value="#15803D" />
        </Style>

        <Style x:Key="LightButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="SecondaryOutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Margin" Value="0" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- CABECERA -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="120"
                                Height="90"
                                CornerRadius="16"
                                Background="#FFF8E1"
                                Padding="12"
                                VerticalAlignment="Top">
                            <Image Source="pack://application:,,,/Assets/Images/hiflunecan.png"
                                   Stretch="Uniform" />
                        </Border>

                        <StackPanel Grid.Column="2">
                            <TextBlock x:Name="HeaderCompanyNameTextBlock"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="#0F172A" />

                            <TextBlock x:Name="HeaderBrandTextBlock"
                                       Margin="0,6,0,0"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="#475569" />

                            <TextBlock x:Name="WelcomeTextBlock"
                                       Margin="0,16,0,8"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       Text="Bienvenido/a" />

                            <TextBlock x:Name="HeaderWelcomeMessageTextBlock"
                                       FontSize="14"
                                       Foreground="#64748B"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Column="2"
                            Background="#F8FAFC"
                            BorderBrush="#D9E1EC"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="Sesión actual"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B"
                                       Margin="0,0,0,12" />

                            <TextBlock x:Name="SessionUserNameTextBlock"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#0F172A" />

                            <TextBlock x:Name="SessionRoleTextBlock"
                                       Margin="0,6,0,0"
                                       FontSize="14"
                                       Foreground="#334155" />

                            <TextBlock x:Name="SessionDailyHoursTextBlock"
                                       Margin="0,4,0,0"
                                       FontSize="14"
                                       Foreground="#334155" />

                            <Button x:Name="ChangeUserButton"
                                    Margin="0,18,0,0"
                                    Width="160"
                                    Content="Cambiar usuario"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource SecondaryOutlineButtonStyle}"
                                    Click="ChangeUserButton_Click" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- TARJETAS RESUMEN -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Estado actual"
                                   Style="{StaticResource MetricLabelStyle}" />

                        <Border x:Name="StatusBadgeBorder"
                                Margin="0,14,0,10"
                                Padding="10,5"
                                CornerRadius="999"
                                HorizontalAlignment="Left"
                                Background="#FDECEC"
                                BorderBrush="#F2B8B5"
                                BorderThickness="1">
                            <TextBlock x:Name="StatusBadgeTextBlock"
                                       Text="FUERA"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#A33A3A" />
                        </Border>

                        <TextBlock x:Name="CurrentStatusValueTextBlock"
                                   Text="Fuera"
                                   Style="{StaticResource MetricValueStyle}" />

                        <TextBlock Margin="0,10,0,0"
                                   Text="Los botones de acción se activan automáticamente según tu estado."
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Tiempo trabajado hoy"
                                   Style="{StaticResource MetricLabelStyle}" />

                        <TextBlock x:Name="WorkedTodayValueTextBlock"
                                   Margin="0,22,0,0"
                                   Text="00:00:00"
                                   Style="{StaticResource MetricValueStyle}" />

                        <TextBlock Margin="0,10,0,0"
                                   Text="Incluye el tiempo de una entrada abierta si todavía no has fichado salida."
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Horas normales"
                                   Style="{StaticResource MetricLabelStyle}" />

                        <TextBlock x:Name="NormalHoursValueTextBlock"
                                   Margin="0,22,0,0"
                                   Text="00:00:00"
                                   Style="{StaticResource MetricValueStyle}" />

                        <TextBlock Margin="0,10,0,0"
                                   Text="Tiempo computado dentro del objetivo diario configurado para tu usuario."
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Horas extra"
                                   Style="{StaticResource MetricLabelStyle}" />

                        <TextBlock x:Name="ExtraHoursValueTextBlock"
                                   Margin="0,22,0,0"
                                   Text="00:00:00"
                                   Style="{StaticResource MetricValueStyle}" />

                        <TextBlock Margin="0,10,0,0"
                                   Text="Tiempo que supera el objetivo diario previsto para hoy."
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- CUERPO PRINCIPAL -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="1.25*" />
                </Grid.ColumnDefinitions>

                <!-- COLUMNA IZQUIERDA -->
                <Border Grid.Column="0"
                        Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Acciones del día"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <TextBlock Margin="0,8,0,20"
                                   Text="Usa estos botones para registrar tu jornada y actualizar el resumen en pantalla."
                                   FontSize="13"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap" />

                        <WrapPanel>
                            <Button x:Name="EntryButton"
                                    Content="Fichar entrada"
                                    Width="160"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Click="EntryButton_Click" />

                            <Button x:Name="ExitButton"
                                    Content="Fichar salida"
                                    Width="160"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ExitButton_Click" />

                            <Button x:Name="RefreshButton"
                                    Content="Actualizar resumen"
                                    Width="170"
                                    Style="{StaticResource LightButtonStyle}"
                                    Click="RefreshButton_Click" />
                        </WrapPanel>

                        <Border x:Name="MessageBorder"
                                Margin="0,20,0,0"
                                Padding="14"
                                CornerRadius="12"
                                Background="#EEF6FF"
                                BorderBrush="#BFD7FF"
                                BorderThickness="1"
                                Visibility="Collapsed">
                            <TextBlock x:Name="MessageTextBlock"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#1D4F91"
                                       TextWrapping="Wrap" />
                        </Border>

                        <Separator Margin="0,22,0,18" />

                        <TextBlock Text="Resumen rápido"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Última entrada"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock x:Name="LastEntryValueTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource FieldValueStyle}" />

                                <TextBlock Text="Objetivo diario"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock x:Name="DailyTargetValueTextBlock"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource FieldValueStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Última salida"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock x:Name="LastExitValueTextBlock"
                                           Margin="0,4,0,16"
                                           Style="{StaticResource FieldValueStyle}" />

                                <TextBlock Text="Progreso del objetivo"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock x:Name="ProgressValueTextBlock"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource FieldValueStyle}" />
                            </StackPanel>
                        </Grid>

                        <ProgressBar x:Name="DailyProgressBar"
                                     Margin="0,18,0,0"
                                     Height="16"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0" />
                    </StackPanel>
                </Border>

                <!-- COLUMNA DERECHA -->
                <Border Grid.Column="2"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Movimientos de hoy"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <TextBlock Grid.Row="2"
                                   Text="Aquí ves el historial del día en orden descendente, con el fichaje más reciente arriba."
                                   FontSize="13"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap" />

                        <ListBox Grid.Row="4"
                                 x:Name="MovementsListBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Single">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="14"
                                            Background="#F8FAFC"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <TextBlock Text="{Binding}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1E293B" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
<Window x:Class="FichajeDeEmpresa.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HIFLUNECAN S.L. - Control de fichaje"
        Height="640"
        Width="1180"
        MinHeight="620"
        MinWidth="1060"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        WindowState="Maximized"
        Background="#EEF2F7">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D9E1EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#17212B" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748B" />
        </Style>

        <Style x:Key="FieldValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#17212B" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748B" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#17212B" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#15803D" />
            <Setter Property="BorderBrush" Value="#15803D" />
        </Style>

        <Style x:Key="SecondaryOutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Margin" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="84"
                        Height="64"
                        CornerRadius="12"
                        Background="#FFF8E1"
                        Padding="8"
                        VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/Images/hiflunecan.png"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderCompanyNameTextBlock"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A" />

                    <TextBlock x:Name="HeaderBrandTextBlock"
                               Margin="0,2,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#475569" />

                    <TextBlock x:Name="WelcomeTextBlock"
                               Margin="0,10,0,4"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#1E293B"
                               Text="Bienvenido/a" />

                    <TextBlock x:Name="HeaderWelcomeMessageTextBlock"
                               FontSize="13"
                               Foreground="#64748B"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="4"
                        Background="#F8FAFC"
                        BorderBrush="#D9E1EC"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="Sesión actual"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#64748B"
                                   Margin="0,0,0,8" />

                        <TextBlock x:Name="SessionUserNameTextBlock"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#0F172A" />

                        <TextBlock x:Name="SessionRoleTextBlock"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="#334155" />

                        <TextBlock x:Name="SessionDailyHoursTextBlock"
                                   Margin="0,3,0,0"
                                   FontSize="13"
                                   Foreground="#334155" />

                        <Button x:Name="ChangeUserButton"
                                Margin="0,12,0,0"
                                Width="150"
                                Content="Cambiar usuario"
                                HorizontalAlignment="Left"
                                Style="{StaticResource SecondaryOutlineButtonStyle}"
                                Click="ChangeUserButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tu jornada de hoy"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="Estado, tiempo trabajado y acciones del día."
                                       FontSize="13"
                                       Foreground="#64748B" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="Estado"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <Border x:Name="StatusBadgeBorder"
                                    Margin="0,8,0,0"
                                    Padding="10,5"
                                    CornerRadius="999"
                                    HorizontalAlignment="Left"
                                    Background="#FDECEC"
                                    BorderBrush="#F2B8B5"
                                    BorderThickness="1">
                                <TextBlock x:Name="StatusBadgeTextBlock"
                                           Text="FUERA"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="#A33A3A" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <WrapPanel Grid.Row="2"
                               ItemWidth="215"
                               ItemHeight="110">
                        <Border Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Width="215"
                                Height="110"
                                Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Tiempo trabajado"
                                           Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="WorkedTodayValueTextBlock"
                                           Margin="0,10,0,0"
                                           Text="00:00:00"
                                           Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Width="215"
                                Height="110"
                                Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Horas normales"
                                           Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="NormalHoursValueTextBlock"
                                           Margin="0,10,0,0"
                                           Text="00:00:00"
                                           Style="{StaticResource MetricValueStyle}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="ExtraHoursCardBorder"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14"
                                Width="215"
                                Height="110"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Horas extra"
                                           Style="{StaticResource MetricLabelStyle}" />
                                <TextBlock x:Name="ExtraHoursValueTextBlock"
                                           Margin="0,10,0,0"
                                           Text="00:00:00"
                                           Style="{StaticResource MetricValueStyle}" />
                                <TextBlock x:Name="ExtraHoursHintTextBlock"
                                           Margin="0,8,0,0"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap"
                                           Text="Hay horas extra hoy." />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Acciones rápidas"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <WrapPanel Margin="0,12,0,0">
                            <Button x:Name="EntryButton"
                                    Content="Fichar entrada"
                                    Width="145"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Click="EntryButton_Click" />

                            <Button x:Name="ExitButton"
                                    Content="Fichar salida"
                                    Width="145"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="ExitButton_Click" />
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Row="6"
                            Background="#F8FAFC"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Objetivo diario"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock x:Name="DailyTargetValueTextBlock"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource FieldValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="8"
                            x:Name="MessageBorder"
                            Padding="12"
                            CornerRadius="12"
                            Background="#EEF6FF"
                            BorderBrush="#BFD7FF"
                            BorderThickness="1"
                            Visibility="Collapsed">
                        <TextBlock x:Name="MessageTextBlock"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1D4F91"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Movimientos de hoy"
                               Style="{StaticResource SectionTitleStyle}" />

                    <TextBlock Grid.Row="2"
                               Text="Aquí ves tu historial del día en orden descendente."
                               FontSize="13"
                               Foreground="#64748B"
                               TextWrapping="Wrap" />

                    <ListBox Grid.Row="4"
                             x:Name="MovementsListBox"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock Text="{Binding}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#1E293B"
                                               TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
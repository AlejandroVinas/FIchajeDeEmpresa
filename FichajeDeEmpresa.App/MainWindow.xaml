<Window x:Class="FichajeDeEmpresa.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Fichaje de Empresa - Pantalla principal"
        Height="520"
        Width="820"
        MinHeight="520"
        MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                Background="White"
                CornerRadius="12"
                BorderBrush="#D9DDE7"
                BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="WelcomeTextBlock"
                           Text="Bienvenido/a"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,8" />

                <TextBlock Text="Esta es la nueva pantalla principal. En el siguiente bloque añadiremos el estado del usuario, los botones de fichaje y el resumen del día."
                           FontSize="14"
                           Foreground="#666666"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="24"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#D9DDE7"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Datos del usuario logueado"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,20" />

                    <TextBlock Text="Id de usuario"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="UserIdValueTextBlock"
                               Margin="0,4,0,16"
                               FontSize="14"
                               Foreground="#333333" />

                    <TextBlock Text="Nombre completo"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="FullNameValueTextBlock"
                               Margin="0,4,0,16"
                               FontSize="14"
                               Foreground="#333333" />

                    <TextBlock Text="Rol"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="RoleValueTextBlock"
                               Margin="0,4,0,16"
                               FontSize="14"
                               Foreground="#333333" />

                    <TextBlock Text="Horas diarias configuradas"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="ExpectedDailyHoursValueTextBlock"
                               Margin="0,4,0,0"
                               FontSize="14"
                               Foreground="#333333" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="24"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#D9DDE7"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Estado del proyecto"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,20" />

                    <TextBlock Text="✔ Login separado de la pantalla principal"
                               Margin="0,0,0,10"
                               FontSize="14" />

                    <TextBlock Text="✔ Datos básicos del usuario visibles"
                               Margin="0,0,0,10"
                               FontSize="14" />

                    <TextBlock Text="➜ Siguiente paso: fichaje en memoria + botones de entrada/salida"
                               Margin="0,0,0,10"
                               FontSize="14" />

                    <TextBlock Text="Todavía no hay fichajes reales en esta pantalla. Esta ventana es la base sobre la que construiremos lo siguiente."
                               Margin="0,16,0,0"
                               TextWrapping="Wrap"
                               Foreground="#666666"
                               FontSize="13" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
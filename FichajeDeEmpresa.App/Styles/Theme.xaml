<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- COLORES BASE -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F7F4EC" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFDF9" />
    <SolidColorBrush x:Key="SoftCardBackgroundBrush" Color="#FBF7EE" />

    <SolidColorBrush x:Key="BorderBrushSoft" Color="#E7DDC8" />
    <SolidColorBrush x:Key="BorderBrushStrong" Color="#D8C79D" />

    <SolidColorBrush x:Key="BrandPrimaryBrush" Color="#D4A62A" />
    <SolidColorBrush x:Key="BrandPrimaryDarkBrush" Color="#A67C12" />
    <SolidColorBrush x:Key="BrandPrimaryLightBrush" Color="#F4E4A6" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#2A2116" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6E624E" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#8A7C67" />
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#2F2411" />

    <SolidColorBrush x:Key="SuccessBrush" Color="#2F7D4A" />
    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="#EAF7EE" />
    <SolidColorBrush x:Key="SuccessBorderBrush" Color="#B8DDBF" />

    <SolidColorBrush x:Key="WarningBrush" Color="#A56A00" />
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFF4D9" />
    <SolidColorBrush x:Key="WarningBorderBrush" Color="#E9C66B" />

    <SolidColorBrush x:Key="DangerBrush" Color="#A33A3A" />
    <SolidColorBrush x:Key="DangerBackgroundBrush" Color="#FDECEC" />
    <SolidColorBrush x:Key="DangerBorderBrush" Color="#E8B5B5" />

    <SolidColorBrush x:Key="InfoBrush" Color="#7B5B12" />
    <SolidColorBrush x:Key="InfoBackgroundBrush" Color="#FFF8E1" />
    <SolidColorBrush x:Key="InfoBorderBrush" Color="#E8D089" />

    <!-- CONTENEDORES -->
    <Style x:Key="AppCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="AppSoftCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SoftCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <!-- TEXTOS -->
    <Style x:Key="AppSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="AppFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>

    <Style x:Key="AppFieldValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="AppMetricLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>

    <Style x:Key="AppMetricValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- BOTONES -->
    <Style x:Key="AppPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="44" />
        <Setter Property="MinWidth" Value="150" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextOnPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrandPrimaryDarkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="AppSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AppPrimaryButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
    </Style>

    <Style x:Key="AppSuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource AppPrimaryButtonStyle}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource SuccessBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
    </Style>

    <Style x:Key="AppWarningButtonStyle" TargetType="Button" BasedOn="{StaticResource AppPrimaryButtonStyle}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource WarningBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}" />
    </Style>

    <Style x:Key="AppDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource AppPrimaryButtonStyle}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource DangerBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
    </Style>

    <!-- INPUTS -->
    <Style x:Key="AppTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="42" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="AppPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Height" Value="42" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="AppComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="42" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="AppDatePickerStyle" TargetType="DatePicker">
        <Setter Property="Height" Value="42" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="White" />
    </Style>
</ResourceDictionary>
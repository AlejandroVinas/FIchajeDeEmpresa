<Window x:Class="FichajeDeEmpresa.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HIFLUNECAN S.L. - Iniciar sesión"
        Height="620"
        Width="980"
        MinHeight="580"
        MinWidth="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="0.95*" />
        </Grid.ColumnDefinitions>

        <!-- PANEL IZQUIERDO -->
        <Border Grid.Column="0"
                Style="{StaticResource AppCardBorderStyle}"
                Padding="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Width="120"
                        Height="92"
                        CornerRadius="18"
                        Background="{StaticResource InfoBackgroundBrush}"
                        BorderBrush="{StaticResource InfoBorderBrush}"
                        BorderThickness="1"
                        Padding="12"
                        HorizontalAlignment="Left">
                    <Image Source="pack://application:,,,/Assets/Images/hiflunecan.png"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Row="2">
                    <TextBlock x:Name="CompanyNameTextBlock"
                               Text="HIFLUNECAN S.L."
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock x:Name="BrandNameTextBlock"
                               Margin="0,8,0,0"
                               Text="Sistema de control horario"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandPrimaryDarkBrush}" />
                </StackPanel>

                <TextBlock Grid.Row="4"
                           x:Name="WelcomeMessageTextBlock"
                           Text="Accede con tu usuario para registrar entrada, pausa, reanudación y salida."
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <!-- PANEL DERECHO -->
        <Border Grid.Column="2"
                Style="{StaticResource AppCardBorderStyle}"
                Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Iniciar sesión"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock Margin="0,8,0,0"
                               Text="Introduce tus credenciales"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Usuario"
                               Style="{StaticResource AppFieldLabelStyle}" />
                    <TextBox x:Name="UserNameTextBox"
                             Style="{StaticResource AppTextBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="Contraseña"
                               Style="{StaticResource AppFieldLabelStyle}" />
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource AppPasswordBoxStyle}" />
                </StackPanel>

                <Button Grid.Row="6"
                        x:Name="LoginButton"
                        Content="Iniciar sesión"
                        Style="{StaticResource AppPrimaryButtonStyle}"
                        Click="LoginButton_Click" />

                <Border Grid.Row="8"
                        x:Name="StatusBorder"
                        Background="{StaticResource SoftCardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="StatusTextBlock"
                               Text=""
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
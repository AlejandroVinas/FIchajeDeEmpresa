<Window x:Class="FichajeDeEmpresa.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HIFLUNECAN S.L. - Inicio de sesión"
        Height="700"
        Width="700"
        MinHeight="680"
        MinWidth="680"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F7">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Background="White"
                BorderBrush="#D9E1EC"
                BorderThickness="1"
                CornerRadius="24"
                Padding="34">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Width="110"
                        Height="82"
                        CornerRadius="18"
                        Background="#FFF8E1"
                        Padding="10"
                        HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/Images/hiflunecan.png"
                           Stretch="Uniform" />
                </Border>

                <TextBlock Grid.Row="2"
                           x:Name="CompanyNameTextBlock"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="4"
                           x:Name="BrandNameTextBlock"
                           FontSize="19"
                           FontWeight="SemiBold"
                           Foreground="#475569"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="6"
                           Text="Acceso al sistema"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#0F172A"
                           TextAlignment="Center" />

                <TextBlock Grid.Row="8"
                           x:Name="WelcomeMessageTextBlock"
                           FontSize="14"
                           Foreground="#64748B"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="50,0,50,0" />

                <StackPanel Grid.Row="10">
                    <TextBlock Text="Usuario"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#475569"
                               Margin="0,0,0,8" />

                    <TextBox x:Name="UserNameTextBox"
                             Height="42"
                             FontSize="14"
                             Padding="12,7" />
                </StackPanel>

                <StackPanel Grid.Row="12">
                    <TextBlock Text="Contraseña"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#475569"
                               Margin="0,0,0,8" />

                    <PasswordBox x:Name="PasswordBox"
                                 Height="42"
                                 FontSize="14"
                                 Padding="12,7"
                                 KeyDown="PasswordBox_KeyDown" />
                </StackPanel>

                <StackPanel Grid.Row="14">
                    <Button x:Name="LoginButton"
                            Content="Iniciar sesión"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="LoginButton_Click" />

                    <Border x:Name="StatusBorder"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="#FDECEC"
                            BorderBrush="#F2B8B5"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="Collapsed">
                        <TextBlock x:Name="StatusTextBlock"
                                   Foreground="#9F1239"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />
                    </Border>

                    <TextBlock Margin="0,14,0,0"
                               Text="Acceso exclusivo para personal autorizado."
                               FontSize="12"
                               Foreground="#94A3B8"
                               TextAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
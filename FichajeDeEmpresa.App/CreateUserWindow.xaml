<Window x:Class="FichajeDeEmpresa.App.CreateUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Crear usuario"
        Height="580"
        Width="760"
        MinHeight="540"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="18">
        <Border Style="{StaticResource AppCardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Crear usuario"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <Border Grid.Row="2"
                        x:Name="MessageBorder"
                        Background="{StaticResource DangerBackgroundBrush}"
                        BorderBrush="{StaticResource DangerBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MessageTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Nombre completo"
                                       Style="{StaticResource AppFieldLabelStyle}" />
                            <TextBox x:Name="FullNameTextBox"
                                     Style="{StaticResource AppTextBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Nombre de usuario"
                                       Style="{StaticResource AppFieldLabelStyle}" />
                            <TextBox x:Name="UserNameTextBox"
                                     Style="{StaticResource AppTextBoxStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Contraseña"
                                       Style="{StaticResource AppFieldLabelStyle}" />
                            <PasswordBox x:Name="PasswordTextBox"
                                         Style="{StaticResource AppPasswordBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Rol"
                                       Style="{StaticResource AppFieldLabelStyle}" />
                            <ComboBox x:Name="RoleComboBox"
                                      Style="{StaticResource AppComboBoxStyle}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="4"
                                HorizontalAlignment="Left"
                                MinWidth="220"
                                MaxWidth="320">
                        <TextBlock Text="Horas diarias objetivo"
                                   Style="{StaticResource AppFieldLabelStyle}" />
                        <TextBox x:Name="ExpectedDailyHoursTextBox"
                                 Style="{StaticResource AppTextBoxStyle}" />
                    </StackPanel>
                </Grid>

                <WrapPanel Grid.Row="6"
                           HorizontalAlignment="Left">
                    <Button x:Name="CreateUserButton"
                            Width="150"
                            Margin="0,0,10,0"
                            Content="Crear usuario"
                            Style="{StaticResource AppPrimaryButtonStyle}"
                            Click="CreateUserButton_Click" />

                    <Button Width="110"
                            Content="Cerrar"
                            Style="{StaticResource AppSecondaryButtonStyle}"
                            Click="CloseButton_Click" />
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
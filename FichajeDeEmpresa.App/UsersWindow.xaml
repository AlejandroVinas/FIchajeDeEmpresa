<Window x:Class="FichajeDeEmpresa.App.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Usuarios del sistema"
        Height="720"
        Width="980"
        MinHeight="640"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppCardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Usuarios del sistema"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock x:Name="UsersCountTextBlock"
                               Margin="0,10,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Total usuarios: 0" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Button x:Name="RefreshButton"
                            Width="140"
                            Margin="0,0,10,0"
                            Content="Actualizar"
                            Style="{StaticResource AppSecondaryButtonStyle}"
                            Click="RefreshButton_Click" />

                    <Button x:Name="EditSelectedUserButton"
                            Width="150"
                            Margin="0,0,10,0"
                            Content="Editar usuario"
                            Style="{StaticResource AppSecondaryButtonStyle}"
                            Click="EditSelectedUserButton_Click" />

                    <Button x:Name="OpenCreateUserButton"
                            Width="150"
                            Content="Crear usuario"
                            Style="{StaticResource AppPrimaryButtonStyle}"
                            Click="OpenCreateUserButton_Click" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource AppCardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        x:Name="MessageBorder"
                        Background="{StaticResource InfoBackgroundBrush}"
                        BorderBrush="{StaticResource InfoBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MessageTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InfoBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="2">
                    <ListView x:Name="UsersListBox"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Width="300" Header="Nombre completo" DisplayMemberBinding="{Binding FullName}" />
                                <GridViewColumn Width="180" Header="Usuario" DisplayMemberBinding="{Binding UserName}" />
                                <GridViewColumn Width="160" Header="Rol" DisplayMemberBinding="{Binding Role}" />
                                <GridViewColumn Width="180" Header="Jornada objetivo" DisplayMemberBinding="{Binding ExpectedDailyHours}" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border x:Name="EmptyStateBorder"
                            Style="{StaticResource AppSoftCardBorderStyle}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Visibility="Collapsed">
                        <TextBlock Text="No hay usuarios."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
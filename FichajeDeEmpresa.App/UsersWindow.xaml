<Window x:Class="FichajeDeEmpresa.App.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Usuarios del sistema"
        Height="720"
        Width="1080"
        MinHeight="640"
        MinWidth="940"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}">

    <Window.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppCardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Usuarios del sistema"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock x:Name="UsersCountTextBlock"
                               Margin="0,10,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Text="Total usuarios: 0" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Buscar usuario"
                                   Style="{StaticResource AppFieldLabelStyle}" />
                        <TextBox x:Name="SearchTextBox"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 TextChanged="SearchTextBox_TextChanged" />
                    </StackPanel>

                    <WrapPanel Grid.Column="2"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom">
                        <Button x:Name="RefreshButton"
                                Width="120"
                                Margin="0,0,10,0"
                                Content="Actualizar"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Click="RefreshButton_Click" />

                        <Button x:Name="EditSelectedUserButton"
                                Width="130"
                                Margin="0,0,10,0"
                                Content="Editar"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Click="EditSelectedUserButton_Click" />

                        <Button x:Name="ToggleActiveUserButton"
                                Width="150"
                                Margin="0,0,10,0"
                                Content="Desactivar"
                                Style="{StaticResource AppSecondaryButtonStyle}"
                                Click="ToggleActiveUserButton_Click" />

                        <Button x:Name="DeleteSelectedUserButton"
                                Width="120"
                                Margin="0,0,10,0"
                                Content="Borrar"
                                Style="{StaticResource AppDangerButtonStyle}"
                                Click="DeleteSelectedUserButton_Click" />

                        <Button x:Name="OpenCreateUserButton"
                                Width="150"
                                Content="Crear usuario"
                                Style="{StaticResource AppPrimaryButtonStyle}"
                                Click="OpenCreateUserButton_Click" />
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource AppCardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        x:Name="MessageBorder"
                        Background="{StaticResource InfoBackgroundBrush}"
                        BorderBrush="{StaticResource InfoBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MessageTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InfoBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="2">
                    <ListView x:Name="UsersListBox"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              SelectionChanged="UsersListBox_SelectionChanged">
                        <ListView.View>
                            <GridView AllowsColumnReorder="False">
                                <GridViewColumn Width="280" Header="Nombre completo" DisplayMemberBinding="{Binding FullName}" />
                                <GridViewColumn Width="170" Header="Usuario" DisplayMemberBinding="{Binding UserName}" />
                                <GridViewColumn Width="120" Header="Rol" DisplayMemberBinding="{Binding Role}" />
                                <GridViewColumn Width="140" Header="Estado" DisplayMemberBinding="{Binding IsActive}" />
                                <GridViewColumn Width="170" Header="Jornada objetivo" DisplayMemberBinding="{Binding ExpectedDailyHours}" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border x:Name="EmptyStateBorder"
                            Style="{StaticResource AppSoftCardBorderStyle}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Visibility="Collapsed">
                        <TextBlock Text="No hay usuarios que coincidan con la búsqueda."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
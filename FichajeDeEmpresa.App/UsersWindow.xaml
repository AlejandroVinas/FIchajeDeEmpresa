<Window x:Class="FichajeDeEmpresa.App.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Usuarios del sistema"
        Height="720"
        Width="980"
        MinHeight="680"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#EEF2F7">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D9E1EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,0" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Usuarios del sistema"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#17212B" />

                    <TextBlock x:Name="UsersCountTextBlock"
                               Margin="0,12,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#475569"
                               Text="Total usuarios: 0" />
                </StackPanel>

                <Button Grid.Column="2"
                        x:Name="RefreshButton"
                        Width="150"
                        Content="Actualizar lista"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="RefreshButton_Click" />

                <Button Grid.Column="4"
                        x:Name="OpenCreateUserButton"
                        Width="150"
                        Content="Crear usuario"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OpenCreateUserButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        x:Name="MessageBorder"
                        Padding="12"
                        CornerRadius="12"
                        Background="#EEF6FF"
                        BorderBrush="#BFD7FF"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <TextBlock x:Name="MessageTextBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1D4F91"
                               TextWrapping="Wrap" />
                </Border>

                <ListBox Grid.Row="2"
                         x:Name="UsersListBox"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    Padding="16"
                                    Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="200" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding FullName}"
                                                   FontSize="17"
                                                   FontWeight="Bold"
                                                   Foreground="#17212B" />

                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding UserName, StringFormat=Usuario: {0}}"
                                                   FontSize="13"
                                                   Foreground="#475569" />

                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Role, StringFormat=Rol: {0}}"
                                                   FontSize="13"
                                                   Foreground="#475569" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Background="White"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="12"
                                            Margin="12,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Jornada objetivo"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#64748B" />

                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ExpectedDailyHours, StringFormat={}{0} horas/día}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="#17212B" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2"
                        x:Name="EmptyStateBorder"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="22"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Visibility="Collapsed">
                    <TextBlock Text="No hay usuarios."
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#475569" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
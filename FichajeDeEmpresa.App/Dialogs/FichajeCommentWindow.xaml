<Window x:Class="FichajeDeEmpresa.App.Dialogs.FichajeCommentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Comentario opcional"
        Height="360"
        Width="560"
        MinHeight="360"
        MinWidth="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#EEF2F7">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Border Background="White"
                BorderBrush="#D9E1EC"
                BorderThickness="1"
                CornerRadius="16"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Comentario opcional"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#17212B" />

                <TextBlock Grid.Row="2"
                           x:Name="ActionTextBlock"
                           FontSize="13"
                           Foreground="#64748B"
                           TextWrapping="Wrap" />

                <TextBox Grid.Row="4"
                         x:Name="CommentTextBox"
                         Height="120"
                         FontSize="14"
                         Padding="12"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         VerticalContentAlignment="Top" />

                <Button Grid.Row="6"
                        x:Name="ConfirmButton"
                        Width="170"
                        HorizontalAlignment="Left"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ConfirmButton_Click" />

                <TextBlock Grid.Row="8"
                           Text="Puedes dejar el comentario vacío y continuar igualmente. Para cancelar, cierra la ventana con la X."
                           FontSize="12"
                           Foreground="#94A3B8"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
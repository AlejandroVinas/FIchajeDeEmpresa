PORT=3000
JWT_SECRET=pon_aqui_un_secreto_largo_y_aleatorio_min_32_chars
JWT_REFRESH_SECRET=otro_secreto_distinto_para_refresh_tokens_min_32_chars

# Orígenes permitidos para CORS (panel admin). Separados por coma.
# Ejemplo producción: https://panel.empresa.com
# Ejemplo desarrollo: http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Coordenadas de la sede (móvil/GPS)
EMPRESA_LAT=40.416775
EMPRESA_LON=-3.703790
EMPRESA_RADIO_METROS=100

# IP(s) públicas de la empresa para fichaje desde escritorio (separadas por coma)
EMPRESA_IPS=1.2.3.4

# Credenciales del primer admin — usadas por seed.js
SEED_EMAIL=admin@empresa.com
SEED_PASSWORD=cambia_esta_contraseña
SEED_NOMBRE=Administrador

# VAPID — generar con: npm run vapid
VAPID_EMAIL=admin@tuempresa.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

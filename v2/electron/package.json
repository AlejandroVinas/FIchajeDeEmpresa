{
  "name": "fichaje-desktop",
  "version": "2.0.0",
  "description": "Sistema de Fichaje — Panel de Administración",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "dev":          "electron .",
    "build:panel":  "cd ../admin_panel && npm run build",
    "build:win":    "npm run build:panel && electron-builder --win",
    "build:mac":    "npm run build:panel && electron-builder --mac",
    "build:linux":  "npm run build:panel && electron-builder --linux",
    "build:all":    "npm run build:panel && electron-builder --win --mac --linux"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "bcryptjs":       "^2.4.3",
    "cookie-parser":  "^1.4.6",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.5",
    "express":        "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken":   "^9.0.2",
    "pino":           "^9.2.0",
    "web-push":       "^3.6.7"
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "com.fichaje.desktop",
    "productName": "Fichaje",
    "copyright":   "Copyright © 2025",
    "asar":        true,

    "files": [
      "src/**/*",
      "backend/**/*",
      "panel_dist/**/*",
      "!backend/node_modules/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to":   "backend",
        "filter": [
          "**/*",
          "!node_modules/**",
          "!*.db",
          "!.env",
          "!fichajes.db"
        ]
      },
      {
        "from": "../admin_panel/dist",
        "to":   "panel_dist"
      }
    ],

    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon":   "assets/icon.ico"
    },
    "nsis": {
      "oneClick":           false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":      "assets/icon.ico",
      "uninstallerIcon":    "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName":       "Fichaje"
    },

    "mac": {
      "target":   [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon":     "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "dmg": {
      "title": "Instalar Fichaje"
    },

    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon":   "assets/icon.png",
      "category": "Office"
    }
  }
}
